# AgriChat Environment Variables
# Copy and update these values with your actual credentials

# OpenAI
OPENAI_API_KEY=test
# WhatsApp Business API
WHATSAPP_PHONE_NUMBER_ID=YOUR_PHONE_NUMBER_ID
WHATSAPP_ACCESS_TOKEN=YOUR_ACCESS_TOKEN
WHATSAPP_APP_SECRET=YOUR_APP_SECRET
WHATSAPP_VERIFY_TOKEN=agrichat_verify_token_dev

# OpenWeatherMap
OPENWEATHER_API_KEY=YOUR_OPENWEATHER_API_KEY

# Azure Cosmos DB
COSMOS_CONNECTION_STRING=YOUR_COSMOS_CONNECTION_STRING
COSMOS_DB_NAME=agrichat
COSMOS_CONTAINER_NAME=interactions

# Logging
LOG_LEVEL=INFO
